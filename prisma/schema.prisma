datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Shop {
  id                  String    @id @default(uuid())
  name                String
  subdomain           String    @unique
  username            String    @unique
  email               String?   @unique
  password            String    // Hashed password

  // Password reset
  resetToken          String?   // SHA-256 hash of the reset token
  resetTokenExpiry    DateTime?
  
  // Subscription settings
  subscriptionPlan     String    @default("SILVER") // SILVER, GOLD, PLATINUM
  subscriptionStatus   String    @default("ACTIVE") // ACTIVE, EXPIRED, SUSPENDED
  subscriptionStart    DateTime  @default(now())
  subscriptionEnd      DateTime?
  
  // WhatsApp settings per shop
  whatsappType         String     @default("BUSINESS") // BUSINESS or NORMAL
  whatsappPhoneId      String?    @unique
  whatsappToken        String?
  whatsappVerifyToken  String?
  whatsappAdminGroupId String?
  
  // Ultramsg settings (Standard WhatsApp)
  ultramsgInstanceId   String?
  ultramsgToken        String?
  
  // AI settings per shop
  aiProvider          String     @default("OPENAI") // OPENAI or GEMINI
  geminiApiKey        String?
  openaiApiKey        String?
  
  // Stripe settings per shop
  stripeSecretKey     String?
  stripeWebhookSecret String?
  stripeSuccessUrl    String?
  stripeCancelUrl    String?

  logoUrl             String?   // شعار/أيقونة المتجر

  deliveryStartHour   String    @default("09:00")
  deliveryEndHour     String    @default("22:00")

  createdAt           DateTime  @default(now())
  products            Product[]
  orders              Order[]
  sessions            Session[]
}

model PlatformSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @default(now())
}

model Prospect {
  id          String    @id @default(uuid())
  name        String    // اسم المتجر/المحل المستهدف
  city        String?
  phone       String?   // رقم تواصل (واتساب)
  instagram   String?
  source      String?   // من أين وُجد: انستقرام، خرائط جوجل، ترشيح...
  status      String    @default("NEW") // NEW, CONTACTED, INTERESTED, DEMO, WON, LOST
  notes       String    @default("")
  lastContact DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
}

model Product {
  id          String   @id @default(uuid())
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  name        String
  description String
  price       Float
  imageUrl    String
  category    String
  available   Boolean  @default(true)
  stock       Int      @default(10)

  @@index([shopId])
}

model Order {
  id              String   @id @default(uuid())
  shopId          String
  shop            Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  timestamp       DateTime @default(now())
  customerName    String
  customerPhone   String
  recipientName   String
  productName     String
  price           Float
  paymentStatus   String   // PENDING, CONFIRMED, FAILED
  locationUrl     String
  stripeSessionId String?
  cardLast4       String?
  productId       String?

  @@index([shopId, timestamp])
  @@index([shopId, paymentStatus])
  @@index([stripeSessionId])
}

model Session {
  id                String   @id @default(uuid())
  phone             String
  shopId            String
  shop              Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  state             String   // ConversationState mapping
  messages          String   // JSON string of ChatMessage[]
  lastActivity      BigInt   // Timestamp in milliseconds
  selectedProductId String?  // Optional selected product ID
  orderData         String   // JSON string of Partial<Order>
  botPaused         Boolean  @default(false)

  @@unique([phone, shopId])
  @@index([shopId, lastActivity])
  @@index([lastActivity])
}
