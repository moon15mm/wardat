datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Shop {
  id                  String    @id @default(uuid())
  name                String
  subdomain           String    @unique
  username            String    @unique
  email               String?   @unique
  password            String    // Hashed password

  ownerPhone          String?   // رقم هاتف صاحب المتجر (لإدارة الكتالوج)
  ownerJid            String?   // WhatsApp JID الفعلي للمالك (يُحفظ تلقائياً)
  ownerTelegramId     String?   // Telegram Chat ID للمالك (لإدارة الكتالوج)

  // Password reset
  resetToken          String?   // SHA-256 hash of the reset token
  resetTokenExpiry    DateTime?
  
  // Subscription settings
  subscriptionPlan     String    @default("SILVER") // SILVER, GOLD, PLATINUM
  subscriptionStatus   String    @default("ACTIVE") // ACTIVE, EXPIRED, SUSPENDED
  subscriptionStart    DateTime  @default(now())
  subscriptionEnd      DateTime?
  
  // Automated WhatsApp Status Posts
  autoPostStatus       Boolean   @default(false)
  autoPostStatusTime   String?   @default("10:00") // Time of day to post status
  
  // WhatsApp settings per shop
  whatsappType         String     @default("BUSINESS") // BUSINESS or NORMAL
  whatsappPhoneId      String?    @unique
  whatsappToken        String?
  whatsappVerifyToken  String?
  whatsappAdminGroupId String?
  
  // Ultramsg settings (Standard WhatsApp)
  ultramsgInstanceId   String?
  ultramsgToken        String?
  
  // AI settings per shop
  aiProvider          String     @default("OPENAI") // OPENAI or GEMINI
  geminiApiKey        String?
  openaiApiKey        String?
  
  // Stripe settings per shop
  paymentGateway      String    @default("STRIPE") // STRIPE, MOYASAR, TAP, MYFATOORAH
  stripeSecretKey     String?
  stripeWebhookSecret String?
  stripeSuccessUrl    String?
  stripeCancelUrl     String?
  moyasarApiKey       String?
  tapApiKey           String?
  myfatoorahApiKey    String?

  logoUrl             String?   // شعار/أيقونة المتجر

  deliveryStartHour   String    @default("09:00")
  deliveryEndHour     String    @default("22:00")

  // خيارات الاستلام
  enableDelivery      Boolean   @default(true)  // تفعيل/إيقاف خيار التوصيل
  enablePickup        Boolean   @default(true)  // تفعيل/إيقاف خيار الاستلام من المحل

  // خيارات الدفع
  enableOnlinePayment Boolean   @default(true)  // دفع إلكتروني (Stripe)
  enableCashPayment   Boolean   @default(false) // دفع نقدًا عند الاستلام

  createdAt           DateTime  @default(now())
  products            Product[]
  orders              Order[]
  sessions            Session[]
  blockedCustomers    BlockedCustomer[]
}

model PlatformSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @default(now())
}

model Prospect {
  id          String    @id @default(uuid())
  name        String    // اسم المتجر/المحل المستهدف
  city        String?
  phone       String?   // رقم تواصل (واتساب)
  instagram   String?
  source      String?   // من أين وُجد: انستقرام، خرائط جوجل، ترشيح...
  status      String    @default("NEW") // NEW, CONTACTED, INTERESTED, DEMO, WON, LOST
  notes       String    @default("")
  lastContact DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
}

model Product {
  id          String   @id @default(uuid())
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  name        String
  description String
  price       Float
  imageUrl    String
  category    String
  available   Boolean  @default(true)
  stock       Int      @default(10)

  @@index([shopId])
}

model Order {
  id              String   @id @default(uuid())
  shopId          String
  shop            Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  timestamp       DateTime @default(now())
  customerName    String
  customerPhone   String
  recipientName   String
  recipientPhone  String?
  productName     String
  price           Float
  paymentStatus   String   // PENDING, CONFIRMED, FAILED
  orderStatus     String   @default("PENDING") // PENDING, DELIVERED, CANCELLED
  locationUrl     String
  fulfillmentType String?  // DELIVERY (توصيل) or PICKUP (استلام من المحل)
  preferredTime   String?  // الوقت المطلوب للتوصيل/الاستلام ضمن ساعات المتجر
  stripeSessionId String?
  cardLast4       String?
  productId       String?

  @@index([shopId, timestamp])
  @@index([shopId, paymentStatus])
  @@index([stripeSessionId])
}

model Session {
  id                String   @id @default(uuid())
  phone             String
  shopId            String
  shop              Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  state             String   // ConversationState mapping
  messages          String   // JSON string of ChatMessage[]
  lastActivity      BigInt   // Timestamp in milliseconds
  selectedProductId String?  // Optional selected product ID
  orderData         String   // JSON string of Partial<Order>
  botPaused         Boolean  @default(false)
  recoverySent      Boolean  @default(false) // Tracks if abandoned cart message was sent

  @@unique([phone, shopId])
  @@index([shopId, lastActivity])
  @@index([lastActivity])
}

model BlockedCustomer {
  id        String   @id @default(uuid())
  shopId    String
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  phone     String
  reason    String?
  createdAt DateTime @default(now())

  @@unique([shopId, phone])
}
