# WhatsApp Cloud API (Meta)
WHATSAPP_TOKEN=your_whatsapp_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_VERIFY_TOKEN=your_webhook_verify_token
WHATSAPP_ADMIN_GROUP_ID=your_admin_group_id
# REQUIRED in production: Meta App Secret used to verify incoming webhook signatures.
# Meta App Dashboard > Settings > Basic > App Secret.
# If left empty, webhook signatures are NOT verified (insecure).
WHATSAPP_APP_SECRET=your_meta_app_secret

# Ultramsg (Standard WhatsApp) — optional shared secret.
# If set, append ?token=THIS_VALUE to the webhook URL you register in Ultramsg.
ULTRAMSG_WEBHOOK_TOKEN=your_ultramsg_webhook_token

# OpenAI
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4.1-nano

# Stripe
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
STRIPE_SUCCESS_URL=https://yoursite.com/success
STRIPE_CANCEL_URL=https://yoursite.com/cancel

# Server
PORT=3000
NODE_ENV=development

# Currency
CURRENCY=SAR

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/dbname?schema=public

# -------------------------------------------------------------
# Security (REQUIRED — the app refuses to start without SESSION_SECRET)
# -------------------------------------------------------------
# Super Admin Dashboard credentials. Super Admin login is DISABLED if ADMIN_PASSWORD is empty.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_to_a_strong_password

# Strong random secret for JWT signing. REQUIRED.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=

# Legacy password salt — only needed if you have shops created before bcrypt was
# introduced. Defaults to the original built-in value so old logins still work and
# get auto-upgraded to bcrypt on next login. Leave as-is unless you know otherwise.
LEGACY_PASSWORD_SECRET=wardat-default-secret-key-123456

# Auth token lifetime in seconds (default 86400 = 24h)
TOKEN_TTL_SECONDS=86400

# -------------------------------------------------------------
# Email (password reset) — SMTP
# If left blank, reset emails are NOT sent; the reset link is logged instead (dev only).
# Works with any SMTP provider (Gmail App Password, SendGrid, Mailgun, etc.)
# -------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password_or_app_password
SMTP_FROM="وردات <no-reply@wardat.xyz>"

# Public base URL used to build the password-reset link in emails.
# If unset, it is inferred from the incoming request host.
APP_BASE_URL=https://wardat.xyz
